      "type": "string",
      "description": "\u7d50\u672b\u3092\u8868\u3059\u7d75\u6587\u5b57"
    },
    "ending_text": {
      "type": "string",
      "description": "\u7d50\u672b\u306e\u8a73\u7d30\u8aac\u660e\u6587"
    },
    "condition_description": {
      "type": "string",
      "description": "\u3053\u306e\u7d50\u672b\u306b\u306a\u308b\u6761\u4ef6\u306e\u8aac\u660e\uff08\u7ba1\u7406\u7528\uff09"
    },
    "min_total_score": {
