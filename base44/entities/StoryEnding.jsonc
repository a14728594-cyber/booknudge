    "required_low_stat": {
      "type": "string",
      "enum": [
        "sales",
        "brand",
        "trust",
        "resource",
        ""
      ],
      "description": "\u7279\u5b9a\u30b9\u30bf\u30c3\u30c8\u304c\u4f4e\u3044\u5834\u5408\u306b\u767a\u52d5\uff08\u30aa\u30d7\u30b7\u30e7\u30f3\uff09"
    }
  },
  "required": [
    "episode_id",
    "ending_key",
    "title",
    "ending_text"
  ]
