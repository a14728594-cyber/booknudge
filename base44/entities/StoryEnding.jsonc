        "failure",
        "bankruptcy"
      ],
      "description": "\u7d50\u672b\u30bf\u30a4\u30d7"
    },
    "title": {
      "type": "string",
      "description": "\u7d50\u672b\u30bf\u30a4\u30c8\u30eb\uff08\u4f8b\uff1a\u300c\u5730\u57df\u306e\u661f\u306b\u306a\u3063\u305f\u300d\uff09"
    },
