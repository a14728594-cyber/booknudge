      "description": "\u3053\u306e\u7d50\u672b\u306b\u306a\u308b\u6700\u4f4e\u30b9\u30b3\u30a2\u5408\u8a08\uff08sales+brand+trust+resource\uff09"
    },
    "max_total_score": {
      "type": "number",
      "description": "\u3053\u306e\u7d50\u672b\u306b\u306a\u308b\u6700\u9ad8\u30b9\u30b3\u30a2\u5408\u8a08"
    },
    "required_high_stat": {
      "type": "string",
      "enum": [
        "sales",
        "brand",
        "trust",
        "resource",
        ""
      ],
      "description": "\u7279\u5b9a\u30b9\u30bf\u30c3\u30c8\u304c\u9ad8\u3044\u5834\u5408\u306b\u512a\u5148\u3055\u308c\u308b\uff08\u30aa\u30d7\u30b7\u30e7\u30f3\uff09"
